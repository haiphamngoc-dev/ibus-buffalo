<component>
    <name>org.freedesktop.IBus.buffalo</name>
    <description>Vietnamese input engine for IBus</description>
    <exec>/usr/lib/ibus-buffalo/ibus-buffalo --ibus</exec>
    <version>0.1.1</version>
    <author>Hai Pham Ngoc</author>
    <license>GPLv3</license>
    <homepage>https://github.com/haiphamngoc-dev/ibus-buffalo</homepage>
    <textdomain>ibus-buffalo</textdomain>
    <engines>
          <engine>
              <symbol>vi</symbol>
              <name>Buffalo</name>
              <language>vi</language>
              <license>GPLv3</license>
              <author>Hai Pham Ngoc</author>
              <icon>/usr/share/ibus-buffalo/icons/vi.svg</icon>
              <layout>default</layout>
              <longname>Buffalo</longname>
              <description>Vietnamese input method engine</description>
              <setup>/usr/lib/ibus-buffalo/buffalo-ui</setup>
              <rank>1</rank>
          </engine>
          <engine>
              <symbol>vi</symbol>
              <name>Buffalo::Us</name>
              <language>vi</language>
              <license>GPLv3</license>
              <author>Hai Pham Ngoc</author>
              <icon>/usr/share/ibus-buffalo/icons/vi.svg</icon>
              <layout>us</layout>
              <longname>Buffalo (US layout)</longname>
              <description>Vietnamese input method engine with US keyboard layout</description>
              <setup>/usr/lib/ibus-buffalo/buffalo-ui</setup>
              <rank>1</rank>
          </engine>
    </engines>
</component>
